        {
          "name": "Auth - Register",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Citizen Demo\",\n  \"email\": \"citizen@example.com\",\n  \"password\": \"Pass@12345\",\n  \"phoneNumber\": \"+15550001111\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/Auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "Auth", "register"]
            }
          }
        },
        {
          "name": "Auth - Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const response = pm.response.json();",
                  "const data = response.data || response.Data;",
                  "if (data) {",
                  "  pm.collectionVariables.set('accessToken', data.accessToken || data.AccessToken || '');",
                  "  pm.collectionVariables.set('refreshToken', data.refreshToken || data.RefreshToken || '');",
                  "  if (data.user || data.User) {",
                  "    const user = data.user || data.User;",
                  "    pm.collectionVariables.set('userId', user.id || user.Id || pm.collectionVariables.get('userId'));",
                  "  }",
                  "}",
                  "pm.test('Access token is captured', function () {",
                  "  pm.expect(pm.collectionVariables.get('accessToken')).to.not.be.empty;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"citizen@example.com\",\n  \"password\": \"Pass@12345\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/Auth/Login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "Auth", "Login"]
            }
          }
        },
